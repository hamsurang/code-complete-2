{
  "name": "hamsurang-code-complete-2",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "lint": "eslint \"{src,docs}/**/*.{ts,tsx,js,jsx,md,mdx}\" --max-warnings 0 --format compact",
    "lint:fix": "pnpm lint --fix",
    "format": "prettier --write \"{src,docs,scripts,.github}/**/*.{ts,tsx,js,jsx,md,mdx,json,yml,yaml}\"",
    "format:check": "prettier --check \"{src,docs,scripts,.github}/**/*.{ts,tsx,js,jsx,md,mdx,json,yml,yaml}\"",
    "verify:human-only": "node scripts/verify-human-only-hash.js"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/tsconfig": "^3.9.2",
    "@docusaurus/types": "3.9.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-mdx": "^3.0.0",
    "eslint-plugin-react": "^7.35.0",
    "prettier": "^3.3.0",
    "typescript": "^5.9.3",
    "yaml": "^2.5.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
